{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CFODiagnosis",
  "description": "Diagnosis emitted by CFO Lite to Action Engine",
  "type": "object",
  "required": [
    "diagnosis_id",
    "tenant_id",
    "timestamp",
    "type",
    "targets",
    "recommended_action",
    "evidence"
  ],
  "properties": {
    "diagnosis_id": {
      "type": "string",
      "description": "Unique identifier for this diagnosis",
      "pattern": "^diag-[0-9]+-[a-z0-9]+$"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of diagnosis creation"
    },
    "type": {
      "type": "string",
      "enum": ["CC_TREND_HIGH", "HIGH_FRAGILITY", "GREEDY_TRAP"],
      "description": "Type of detected anomaly"
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of affected service_logical_ids"
    },
    "recommended_action": {
      "type": "object",
      "required": ["type", "params"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["SWAP_VARIANT", "CONFIG_TUNE", "BUFFER_ENABLE", "DEGRADE_MODE"]
        },
        "params": {
          "type": "object",
          "description": "Action-specific parameters"
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["baseline_cc", "current_cc", "cc_formula", "threshold_cc", "breach_duration_seconds"],
      "properties": {
        "baseline_cc": { "type": "number" },
        "current_cc": { "type": "number" },
        "cc_formula": { "type": "string" },
        "threshold_cc": { "type": "number" },
        "breach_duration_seconds": { "type": "number" },
        "cc_series": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "t": { "type": "number" },
              "cc": { "type": "number" }
            }
          }
        },
        "mcp_observe_snapshot": { "type": "object" }
      }
    }
  }
}
